{
  "name": "pdf-ar-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Arabic real-estate PDF generation engine and visual builder.",
  "license": "ISC",
  "type": "commonjs",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "npm run start -w @pdf-ar/builder",
    "dev": "npm run dev -w @pdf-ar/builder",
    "build": "npm run build --workspaces --if-present",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.19.4"
  }
}
